# Postgres connection string from Supabase.
# Use the transaction pooler endpoint on port 6543 for serverless.
# Format: postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require
DATABASE_URL=

# Optional: override the API base URL.
# Defaults to /api (same-origin) which works for both `next dev` (proxy)
# and Vercel production (vercel.json rewrite).
NEXT_PUBLIC_API_URL=
